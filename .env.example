# Copy to .env.local and fill in values
# NEVER commit .env.local to git

# App
NEXT_PUBLIC_APP_URL=https://zoundlist.com
NEXT_PUBLIC_APP_NAME=Zoundlist

# SEO — Google Search Console (URL-prefix verification). Paste the token
# from the meta tag Google gives you (the content="..." value, without quotes).
GOOGLE_SITE_VERIFICATION=

# Supabase (add when integrating auth/db)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (add when integrating payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (add when integrating email)
RESEND_API_KEY=
