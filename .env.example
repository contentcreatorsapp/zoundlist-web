# Copy to .env.local and fill in values
# NEVER commit .env.local to git

# App
NEXT_PUBLIC_APP_URL=https://zoundlist.com
NEXT_PUBLIC_APP_NAME=Zoundlist

# SEO — Google Search Console (URL-prefix verification). Paste the token
# from the meta tag Google gives you (the content="..." value, without quotes).
GOOGLE_SITE_VERIFICATION=

# Supabase (add when integrating auth/db)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase service role (server-only; usado por checkout/webhook de Stripe)
# NUNCA exponer en el cliente. Project Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (modo test para empezar)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs de cada plan (Stripe → Products). Empiezan con price_...
STRIPE_PRICE_CREATOR=
STRIPE_PRICE_PRO=
STRIPE_PRICE_CHURCH=

# Resend (add when integrating email)
RESEND_API_KEY=

# ── AI Publishing Assistant ────────────────────────────────────────────────────
# Required for the AI metadata generation feature (dashboard → album → AI Assistant).
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Active AI provider. Default: anthropic (only fully-implemented option).
# openai and gemini are stubs — they will throw if selected.
AI_PROVIDER=anthropic
