{
  "manifest_version": 3,
  "name": "Zoundlist Suno Importer",
  "version": "1.0.0",
  "description": "Import songs from your Suno library directly into Zoundlist.",

  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": [
    "https://suno.com/*",
    "https://www.suno.com/*",
    "https://zoundlist.com/*",
    "https://cdn1.suno.ai/*"
  ],

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://suno.com/*", "https://www.suno.com/*"],
      "js": ["content/suno-content.js"],
      "css": ["content/suno-content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://zoundlist.com/*"],
      "js": ["content/zoundlist-auth.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Zoundlist Suno Importer",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
